state CounterState {
    int count;
}

actor Counter owns CounterState {
    entry merge()
    consumes {
        other: Counter,
    }
    emits one Counter {
        CounterState next = {
            count: count + other.count,
        };

        become Counter(next);
    }

    entry hold() emits none {
        require(count >= 0);
    }
}

app Test {
    actor Counter;
}
