state ControllerState {
    actor_type<PairState> pair_type;
    int launches;
}

state PairState {
    int amount;
}

actor Controller owns ControllerState {
    entry launch(int left_amount, int right_amount)
    spawns new_pair by pair_id {
        outputs {
            left: self.pair_type,
            right: self.pair_type,
        }
    }
    emits one Controller {
        PairState left = {
            amount: left_amount,
        };
        PairState right = {
            amount: right_amount,
        };
        ControllerState next = {
            pair_type: pair_type,
            launches: launches + 1,
        };

        require new_pair.outputs become {
            left <- self.pair_type(left),
            right <- self.pair_type(right),
        };
        become Controller(next);
    }
}

actor Pair owns PairState {
    entry keep() emits one Pair {
        become Pair(self.state);
    }
}

app ControllerApp {
    actor Controller;
}

app PairApp {
    actor Pair;
}
