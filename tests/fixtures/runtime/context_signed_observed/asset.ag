import "./capsule.ag";

actor Asset owns AssetState {
    entry transfer(pubkey next_owner, sig owner_sig) emits one Asset {
        require(checkSig(owner_sig, owner));

        AssetState next = {
            owner: next_owner,
            amount: amount,
        };

        become Asset(next);
    }
}

app AssetApp {
    actor Asset;
}
