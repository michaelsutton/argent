state ControllerState {
    actor_type<PairState> pair_type;
    int launches;
}

state PairState {
    int value;
}

actor Controller owns ControllerState {
    entry launch(first_left_value: int, first_right_value: int, second_value: int)
    spawns first_pair by first_pair_id {
        outputs {
            left: self.pair_type;
            right: self.pair_type;
        }
    }
    spawns second_pair by second_pair_id {
        outputs {
            pair: self.pair_type;
        }
    }
    emits one Controller {
        PairState first_left = {
            value: first_left_value,
        };
        PairState first_right = {
            value: first_right_value,
        };
        PairState second = {
            value: second_value,
        };
        ControllerState next = {
            pair_type: pair_type,
            launches: launches + 2,
        };

        require first_pair.outputs become {
            left <- self.pair_type(first_left);
            right <- self.pair_type(first_right);
        };
        require second_pair.outputs become {
            pair <- self.pair_type(second);
        };
        become Controller(next);
    }
}

actor Pair owns PairState {
    entry keep() emits one Pair {
        become Pair(self.state);
    }
}

app ControllerApp {
    actor Controller;
}

app PairApp {
    actor Pair;
}
