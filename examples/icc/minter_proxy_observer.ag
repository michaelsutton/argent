// Syntax sketch only: observed foreign covenants are not compiled yet.
//
// This file sketches two separate apps:
// - KCC20Asset: the asset covenant family.
// - KCC20MintController: an external policy covenant that controls a proxy branch.

const byte IDENTIFIER_PUBKEY = 0x00;
const byte IDENTIFIER_COVENANT_ID = 0x02;

state KCC20State {
    byte[32] owner_identifier;
    byte identifier_type;
    int amount;
}

state MinterProxyState {
    covid controller_id;
}

state MinterState {
    pubkey owner;
    covid kcc20_covid;
    int amount;
    bool initialized;
}

actor KCC20 owns KCC20State {
    entry transfer(
        new_owner_identifier: byte[32],
        new_identifier_type: byte,
        owner_sig: sig
    ) emits {
        next: KCC20;
    } {
        if (identifier_type == IDENTIFIER_PUBKEY) {
            require(sigVerify(owner_sig, owner_identifier));
        } else if (identifier_type == IDENTIFIER_COVENANT_ID) {
            require(covid(owner_identifier).authorized());
        } else {
            require(false);
        }

        become next <- KCC20({
            owner_identifier: new_owner_identifier,
            identifier_type: new_identifier_type,
            amount: amount,
        });
    }
}

actor MinterProxy owns MinterProxyState {
    entry mint(
        next_proxy: MinterProxyState,
        recipient: KCC20State
    ) emits {
        proxy: MinterProxy;
        recipient: KCC20;
    } {
        require(controller_id.authorized());
        require(next_proxy.controller_id == controller_id);

        become {
            proxy <- MinterProxy(next_proxy);
            recipient <- KCC20(recipient);
        };
    }
}

app KCC20Asset {
    actor KCC20;
    actor MinterProxy;
}

actor Minter owns MinterState {
    entry mint(owner_sig: sig, recipient_owner: byte[32], minted_amount: int)
    // `observes` declares a foreign covenant id for this transition.
    observes asset by self.kcc20_covid {
        // Named handles are exhaustive over the observed covenant inputs.
        inputs {
            proxy: MinterProxy;
        }

        // Declaration order defines the op_cov_output_idx order; no auth/cov index syntax.
        outputs {
            proxy: MinterProxy;
            recipient: KCC20;
        }
    }
    emits {
        controller: Minter;
    } {
        MinterProxyState prev_proxy = asset.inputs.proxy.state;

        require(sigVerify(owner_sig, owner));
        require(initialized);
        require(amount >= minted_amount);
        require(prev_proxy.controller_id == self.covenant_id);

        MinterProxyState next_proxy = {
            controller_id: self.covenant_id,
        };

        KCC20State next_recipient = {
            owner_identifier: recipient_owner,
            identifier_type: IDENTIFIER_PUBKEY,
            amount: minted_amount,
        };

        require asset.outputs become {
            proxy <- MinterProxy(next_proxy);
            recipient <- KCC20(next_recipient);
        };

        become controller <- Minter({
            owner: owner,
            kcc20_covid: kcc20_covid,
            amount: amount - minted_amount,
            initialized: initialized,
        });
    }
}

app KCC20MintController {
    actor Minter;
}
