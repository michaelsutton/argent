// Open ICC agent app.
//
// Agents own their capability header and authorize controller-led transitions
// by requiring the controller covenant to be co-spent.

state AgentState {
    byte[32] world_id;
    byte[32] agent_id;
    byte[32] species_id;

    covid controller_id;
    byte[32] capabilities_digest;
    byte[32] custom_data_digest;

    int x;
    int y;
    int energy;
    int generation;
}

state ForagerMemory {
    int hunger;
    int mood;
    byte[32] target_agent_id;
}

state ForagerState expands AgentState {
    expand custom_data_digest as ForagerMemory;
}

actor Agent owns AgentState {
    entry step(next_agent: AgentState) emits {
        agent: Agent;
    } {
        require(controller_id.authorized());
        require(next_agent.world_id == world_id);
        require(next_agent.agent_id == agent_id);
        require(next_agent.species_id == species_id);
        require(next_agent.controller_id == controller_id);
        require(next_agent.capabilities_digest == capabilities_digest);
        require(next_agent.custom_data_digest == custom_data_digest);
        require(next_agent.generation == generation);

        become agent <- Agent(next_agent);
    }
}

actor Forager owns ForagerState {
    entry step(next_x: int, next_y: int, next_energy: int) emits {
        agent: Forager;
    } {
        require(controller_id.authorized());
        require(next_energy == energy - 1);
        require(next_energy >= 0);

        ForagerState next_agent = {
            world_id: world_id,
            agent_id: agent_id,
            species_id: species_id,
            controller_id: controller_id,
            capabilities_digest: capabilities_digest,
            hunger: hunger + 1,
            mood: mood,
            target_agent_id: target_agent_id,
            x: next_x,
            y: next_y,
            energy: next_energy,
            generation: generation,
        };

        become agent <- Forager(next_agent);
    }
}

app OpenAgent {
    actor Agent;
    actor Forager;
}
