// This file sketches a richer Argent prototype based on the chess settlement flow.
// It is intentionally not implemented compiler input yet.

// This sketch focuses on the hard part that plain Silverscript exposes manually:
// one settlement actor consumes two foreign Player actors and emits two updated
// Player actors at stable authorized output slots.

// This lowering rule is the central idea for this file:
// `input Player at cov[1]` should lower to `OpCovInputIdx`, prefix/suffix
// witness handling, and `readInputStateWithTemplate`.

// This lowering rule is the second central idea for this file:
// `become { white_out <- Player(...) }` should lower to `OpAuthOutputIdx`,
// value checks, and `validateOutputStateWithTemplate`.

// This constant names the still-running game status.
const int LIVE = 0;

// This constant names a white win.
const int WHITE_WIN = 1;

// This constant names a black win.
const int BLACK_WIN = 2;

// This constant names a draw.
const int DRAW = 3;

// This constant is the integer scale used for expected score buckets.
const int SCORE_SCALE = 1000;

// This constant is the approximate Elo K factor used by the settlement rule.
const int ELO_K = 32;

// This state is the application-visible player account state.
state PlayerState {
    // This field commits to the account owner key hash.
    byte[32] owner;

    // This field is the league-issued stable player id.
    byte[32] player_id;

    // This field counts games that must settle before retirement.
    int open_games;

    // This field stores the current rating.
    int rating;

    // This field counts all settled games.
    int games;

    // This field counts settled wins.
    int wins;

    // This field counts settled draws.
    int draws;

    // This field counts settled losses.
    int losses;
}

// This state is the terminal ticket produced by a finished game.
state SettleState {
    // This field identifies the white player account expected by settlement.
    byte[32] white_player;

    // This field identifies the black player account expected by settlement.
    byte[32] black_player;

    // This field stores the terminal result.
    int status;
}

// This helper returns the absolute value of an integer.
fn abs(value: int) -> int {
    // This branch handles negative values.
    if (value < 0) {
        // This return flips a negative value into a positive value.
        return 0 - value;
    }

    // This return leaves non-negative values unchanged.
    return value;
}

// This helper approximates the expected score in thousandths.
fn expected_score(self_rating: int, opponent_rating: int) -> int {
    // This local value measures how far the opponent is from the player.
    let diff = opponent_rating - self_rating;

    // This local value ignores which side is favored.
    let distance = abs(diff);

    // This mutable local value starts at the most extreme supported bucket.
    var favored_expected = 990;

    // This branch chooses the expected score bucket for the favored player.
    if (distance < 800) {
        // This assignment moves to the next lower bucket.
        favored_expected = 970;

        // This branch chooses the next lower bucket.
        if (distance < 600) {
            // This assignment moves to the next lower bucket.
            favored_expected = 910;

            // This branch chooses the next lower bucket.
            if (distance < 400) {
                // This assignment moves to the next lower bucket.
                favored_expected = 820;

                // This branch chooses the next lower bucket.
                if (distance < 250) {
                    // This assignment moves to the next lower bucket.
                    favored_expected = 700;

                    // This branch chooses the next lower bucket.
                    if (distance < 150) {
                        // This assignment moves to the next lower bucket.
                        favored_expected = 600;

                        // This branch chooses the even-match bucket.
                        if (distance < 75) {
                            // This assignment records an even expected score.
                            favored_expected = 500;
                        }
                    }
                }
            }
        }
    }

    // This branch returns the favored score when self is favored.
    if (diff < 0) {
        // This return gives self the favored-side expectation.
        return favored_expected;
    }

    // This branch returns the underdog score when the opponent is favored.
    if (diff > 0) {
        // This return gives self the unfavored-side expectation.
        return SCORE_SCALE - favored_expected;
    }

    // This return handles equal ratings.
    return 500;
}

// This helper applies the approximate rating update.
fn rating_after(self_rating: int, opponent_rating: int, actual_score: int) -> int {
    // This local value computes the expected score bucket.
    let expected = expected_score(self_rating, opponent_rating);

    // This return applies the integer Elo update.
    return self_rating + ((ELO_K * (actual_score - expected)) / SCORE_SCALE);
}

// This actor represents a player account.
actor Player owns PlayerState {
    // This entrypoint lets a Player input participate in a settlement transaction.
    entry delegate_settle(
        // This foreign input is the settlement leader at covenant input slot 0.
        settle: input ChessSettle at cov[0]
    ) emits none {
        // This requirement ensures the leader is terminal.
        require(settle.status != LIVE);

        // This local value computes this player's stable account reference.
        let self_ref = blake2b(owner + player_id);

        // This requirement ensures the settlement ticket names this player.
        require(self_ref == settle.white_player || self_ref == settle.black_player);
    }
}

// This actor represents a terminal settlement ticket.
actor ChessSettle owns SettleState {
    // This entrypoint settles a completed game back into the two Player accounts.
    entry settle(
        // This foreign input is the white Player account at covenant input slot 1.
        white: input Player at cov[1],

        // This foreign input is the black Player account at covenant input slot 2.
        black: input Player at cov[2]
    ) emits {
        // This authorized output is the updated white Player at auth output slot 0.
        white_out: Player at auth[0];

        // This authorized output is the updated black Player at auth output slot 1.
        black_out: Player at auth[1];
    } {
        // This requirement rejects non-terminal settlement tickets.
        require(status != LIVE);

        // This requirement tells the compiler/runtime shape that this transaction has exactly three covenant inputs.
        require cov.inputs == [self, white, black];

        // This requirement proves the white account is the account named by the ticket.
        require(blake2b(white.owner + white.player_id) == white_player);

        // This requirement proves the black account is the account named by the ticket.
        require(blake2b(black.owner + black.player_id) == black_player);

        // This requirement prevents closing an account lane that was not marked as open.
        require(white.open_games > 0);

        // This requirement prevents closing an account lane that was not marked as open.
        require(black.open_games > 0);

        // This local value carries the stake locked in the settlement ticket.
        let stake = self.value;

        // This mutable local value starts from the white account's current coin value.
        var white_value = white.value;

        // This mutable local value starts from the black account's current coin value.
        var black_value = black.value;

        // This mutable local value starts from the white account's current win count.
        var white_wins = white.wins;

        // This mutable local value starts from the white account's current draw count.
        var white_draws = white.draws;

        // This mutable local value starts from the white account's current loss count.
        var white_losses = white.losses;

        // This mutable local value starts from the black account's current win count.
        var black_wins = black.wins;

        // This mutable local value starts from the black account's current draw count.
        var black_draws = black.draws;

        // This mutable local value starts from the black account's current loss count.
        var black_losses = black.losses;

        // This mutable local value stores white's score in thousandths.
        var white_actual = 0;

        // This mutable local value stores black's score in thousandths.
        var black_actual = 0;

        // This branch handles a white win.
        if (status == WHITE_WIN) {
            // This assignment increments white's wins.
            white_wins = white_wins + 1;

            // This assignment increments black's losses.
            black_losses = black_losses + 1;

            // This assignment gives white a full score.
            white_actual = SCORE_SCALE;

            // This assignment transfers the stake to white.
            white_value = white_value + stake;

        // This branch handles a black win.
        } else if (status == BLACK_WIN) {
            // This assignment increments black's wins.
            black_wins = black_wins + 1;

            // This assignment increments white's losses.
            white_losses = white_losses + 1;

            // This assignment gives black a full score.
            black_actual = SCORE_SCALE;

            // This assignment transfers the stake to black.
            black_value = black_value + stake;

        // This branch handles a draw.
        } else {
            // This requirement rejects unknown terminal statuses.
            require(status == DRAW);

            // This assignment increments white's draws.
            white_draws = white_draws + 1;

            // This assignment increments black's draws.
            black_draws = black_draws + 1;

            // This assignment gives white a half score.
            white_actual = SCORE_SCALE / 2;

            // This assignment gives black a half score.
            black_actual = SCORE_SCALE / 2;

            // This local value gives white the rounded-down half of the stake.
            let white_share = stake / 2;

            // This local value gives black the remainder when the stake is odd.
            let black_share = stake - white_share;

            // This assignment transfers white's draw share.
            white_value = white_value + white_share;

            // This assignment transfers black's draw share.
            black_value = black_value + black_share;
        }

        // This local value computes white's updated rating.
        let white_rating = rating_after(white.rating, black.rating, white_actual);

        // This local value computes black's updated rating.
        let black_rating = rating_after(black.rating, white.rating, black_actual);

        // This local value builds the next white Player state.
        let next_white = PlayerState {
            // This field preserves the white owner.
            owner: white.owner,

            // This field preserves the white player id.
            player_id: white.player_id,

            // This field decrements white's open-game count.
            open_games: white.open_games - 1,

            // This field stores white's new rating.
            rating: white_rating,

            // This field increments white's settled game count.
            games: white.games + 1,

            // This field stores white's new win count.
            wins: white_wins,

            // This field stores white's new draw count.
            draws: white_draws,

            // This field stores white's new loss count.
            losses: white_losses,
        };

        // This local value builds the next black Player state.
        let next_black = PlayerState {
            // This field preserves the black owner.
            owner: black.owner,

            // This field preserves the black player id.
            player_id: black.player_id,

            // This field decrements black's open-game count.
            open_games: black.open_games - 1,

            // This field stores black's new rating.
            rating: black_rating,

            // This field increments black's settled game count.
            games: black.games + 1,

            // This field stores black's new win count.
            wins: black_wins,

            // This field stores black's new draw count.
            draws: black_draws,

            // This field stores black's new loss count.
            losses: black_losses,
        };

        // This atomic become emits both successor Player actors in one transaction shape.
        become {
            // This successor lowers to auth output 0 and validates the Player template.
            white_out <- Player(next_white) value white_value;

            // This successor lowers to auth output 1 and validates the Player template.
            black_out <- Player(next_black) value black_value;
        };
    }
}
