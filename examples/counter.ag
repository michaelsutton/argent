// This file is the smallest useful Argent syntax sketch.
// It is intentionally a design artifact, not an implemented compiler input yet.

// This state is the persistent payload owned by the Counter actor.
state CounterState {
    // This field stores the current counter value.
    int value;

    // This field stores the value at which the counter stops looping.
    int limit;
}

// This state is the persistent payload owned by the terminal Done actor.
state DoneState {
    // This field records the value that caused the counter to finish.
    int final_value;
}

// This actor represents the live counter covenant.
actor Counter owns CounterState {
    // This entrypoint advances the counter by one step.
    entry tick() emits one Counter | Done {
        // This local value computes the next counter value.
        let next_value = value + 1;

        // This branch keeps the protocol live while the limit has not been reached.
        if (next_value < limit) {
            // This tail-dispatch lowers to one authorized output using the Counter template.
            become Counter({
                // This field update carries the incremented value into the next Counter state.
                value: next_value,

                // This field update preserves the stopping limit unchanged.
                limit: limit,
            });
        }

        // This tail-dispatch lowers to one authorized output using the Done template.
        become Done({
            // This field update records the final value in the terminal state.
            final_value: next_value,
        });
    }
}

// This actor represents a terminal covenant state.
actor Done owns DoneState {
    // This entrypoint closes the terminal state without creating another actor.
    entry close() emits none {
        // This assertion is deliberately boring; it gives the terminal entry a visible body.
        require(final_value >= 0);
    }
}

