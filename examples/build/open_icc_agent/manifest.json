{
  "app": "OpenAgent",
  "root": "examples/open_icc/agent.ag",
  "modules": [
    "examples/open_icc/agent.ag"
  ],
  "templates": [
    { "actor": "Agent", "symbol": "gen__agent_template", "hash": null }
  ],
  "actors": [
    {
      "name": "Agent",
      "state": "AgentState",
      "sil": "sil/Agent.sil",
      "entries": [
        {
          "name": "step",
          "kind": "leader",
          "emits": { "kind": "outputs", "outputs": [{ "name": "agent", "auth_index": 0, "actors": ["Agent"] }] },
          "consumes": [],
          "routes": [{ "output": "agent", "actor": "Agent", "state": "next_agent" }]
        }
      ]
    }
  ]
}
