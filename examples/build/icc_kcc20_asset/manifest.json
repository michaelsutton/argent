{
  "app": "KCC20Asset",
  "root": "examples/icc/kcc20_asset.ag",
  "modules": [
    "examples/icc/kcc20_asset.ag"
  ],
  "templates": [
    { "actor": "KCC20", "symbol": "gen__kcc20_template", "hash": null },
    { "actor": "MinterProxy", "symbol": "gen__minter_proxy_template", "hash": null }
  ],
  "actors": [
    {
      "name": "KCC20",
      "state": "KCC20State",
      "sil": "sil/KCC20.sil",
      "entries": [
        {
          "name": "transfer",
          "kind": "leader",
          "emits": { "kind": "outputs", "outputs": [{ "name": "next", "auth_index": 0, "actors": ["KCC20"] }] },
          "consumes": [],
          "routes": [{ "output": "next", "actor": "KCC20", "state": "next_state" }]
        }
      ]
    },
    {
      "name": "MinterProxy",
      "state": "MinterProxyState",
      "sil": "sil/MinterProxy.sil",
      "entries": [
        {
          "name": "mint",
          "kind": "leader",
          "emits": { "kind": "outputs", "outputs": [{ "name": "proxy", "auth_index": 0, "actors": ["MinterProxy"] }, { "name": "recipient", "auth_index": 1, "actors": ["KCC20"] }] },
          "consumes": [],
          "routes": [{ "output": "proxy", "actor": "MinterProxy", "state": "next_proxy" }, { "output": "recipient", "actor": "KCC20", "state": "recipient" }]
        }
      ]
    }
  ]
}
